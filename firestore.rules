rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    
    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email'])
          && data.uid == request.auth.uid
          && data.email is string;
      }
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming())
                     && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'registrationId']);
    }

    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow write: if false; // Only admin can write notices
    }

    match /bookings/{bookingId} {
      function isValidBooking(data) {
        return data.keys().hasAll(['userId', 'status', 'createdAt'])
          && data.userId == request.auth.uid;
      }
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().status == 'Pending' && incoming().createdAt == request.time && isValidBooking(incoming());
    }

    match /complaints/{complaintId} {
      function isValidComplaint(data) {
        return data.keys().hasAll(['userId', 'status', 'createdAt'])
          && data.userId == request.auth.uid;
      }
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().status == 'Pending' && incoming().createdAt == request.time && isValidComplaint(incoming());
    }

    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid 
                    && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
                    && incoming().status == 'Paid';
    }
  }
}
